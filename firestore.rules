rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default safety net: Deny all operations by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Rules for the central persistent state Document.
    // Since our backend server operates using client-side SDK integration within
    // the AI Studio preview environment (unauthenticated client context), we explicitly
    // allow reads and writes to the 'zongobase_system' collection holding the 'state' doc.
    match /zongobase_system/{docId} {
      allow read, write: if true;
    }
  }
}
